{% extends 'base.html.twig' %}

{% block title %}{{ article.title }}{% endblock %}

{% block meta_description %}{{ article.metaDescription ?? article.excerpt ?? parent() }}{% endblock %}

{% block og_type %}article{% endblock %}

{% block og_image %}
    {%- if article.featuredImage -%}
        {{ absolute_url(asset('uploads/articles/' ~ article.featuredImage)) }}
    {%- else -%}
        {{ parent() }}
    {%- endif -%}
{% endblock %}

{% block body %}
    <h1>{{ article.title }}</h1>

    {% if article.featuredImage %}
        <img src="{{ asset('uploads/articles/' ~ article.featuredImage) }}" alt="{{ article.title }}" style="max-width: 500px; border-radius: 8px; margin-bottom: 20px;">
    {% endif %}

    <div class="article-content">{{ article.content|raw }}</div>
{% endblock %}
