{% extends 'base.html.twig' %}

{% block title %}{{ page.title }}{% endblock %}

{% block meta_description %}{{ page.metaDescription ?? parent() }}{% endblock %}

{% block og_image %}
    {%- if page.featuredImage -%}
        {{ absolute_url(asset('uploads/pages/' ~ page.featuredImage)) }}
    {%- else -%}
        {{ parent() }}
    {%- endif -%}
{% endblock %}

{% block body %}
    <h1>{{ page.title }}</h1>

    {% if page.featuredImage %}
        <img src="{{ asset('uploads/pages/' ~ page.featuredImage) }}" alt="{{ page.title }}" style="max-width: 300px; border-radius: 8px;">
    {% endif %}

    <div>{{ page.content|raw }}</div>
{% endblock %}
