<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Agenda - Administration</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <style>
        body { font-family: sans-serif; margin: 0; padding: 24px; background: #f5f5f5; }
        .admin-calendar-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .admin-calendar-header a { color: #1a3a5c; text-decoration: none; font-weight: bold; }
        .admin-calendar-header .header-actions { display: flex; align-items: center; gap: 20px; }
        .admin-calendar-print-btn {
            background: #1a3a5c;
            color: #fff;
            border: none;
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.9rem;
        }
        .admin-calendar-print-btn:hover { background: #142e49; }
        #admin-calendar { max-width: 1100px; margin: 0 auto; background: #fff; padding: 20px; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }

        @media print {
            body { background: #fff; padding: 0; }
            .admin-calendar-header { display: none; }
            #admin-calendar { box-shadow: none; padding: 0; max-width: 100%; }
            .fc-toolbar { display: none !important; }
        }
    </style>
</head>
<body>
    <div class="admin-calendar-header">
        <h1>Agenda</h1>
        <div class="header-actions">
            <button type="button" class="admin-calendar-print-btn" onclick="window.print()">Imprimer la semaine</button>
            <a href="{{ path('admin') }}">&larr; Retour au tableau de bord</a>
        </div>
    </div>

    <div id="admin-calendar"></div>

    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.21/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.21/locales-all.global.min.js"></script>
    <script src="{{ asset('calendar_admin_global.js') }}"></script>
</body>
</html>