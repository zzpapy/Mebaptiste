{% extends 'base.html.twig' %}

{% block title %}Prendre rendez-vous{% endblock %}

{% block body %}
<section class="booking-page">
    <h1>Prendre rendez-vous</h1>

    <div class="booking-step" id="booking-step-consultation">
        <label for="consultation-select">Type de consultation</label>
        <select id="consultation-select">
            <option value="">-- Choisissez --</option>
            {% for consultation in consultations %}
                <option value="{{ consultation.id }}" data-duration="{{ consultation.durationMinutes }}">
                    {{ consultation.name }} ({{ consultation.durationMinutes }} min)
                </option>
            {% endfor %}
        </select>
    </div>

    <div class="booking-step" id="booking-step-calendar" style="display:none;">
        <div id="booking-calendar"></div>
    </div>

    <div class="booking-step" id="booking-step-success" style="display:none;">
        <p>Votre rendez-vous a bien été confirmé. Vous recevrez également un email de confirmation.</p>
    </div>
</section>

<div id="booking-modal-overlay" class="booking-modal-overlay" style="display:none;">
    <div class="booking-modal">
        <button type="button" id="booking-modal-close" class="booking-modal-close" aria-label="Fermer">&times;</button>

        <div id="booking-step-form" style="display:none;">
            <h2>Vos coordonnées</h2>
            <p id="booking-selected-slot"></p>
            <form id="booking-form">
                <label for="booking-firstName">Prénom</label>
                <input type="text" id="booking-firstName" required>

                <label for="booking-lastName">Nom</label>
                <input type="text" id="booking-lastName" required>

                <label for="booking-email">Email</label>
                <input type="email" id="booking-email" required>

                <label for="booking-phone">Téléphone</label>
                <input type="tel" id="booking-phone">

                <label for="booking-message">Message (facultatif)</label>
                <textarea id="booking-message"></textarea>

                <button type="submit">Recevoir le code de vérification</button>
            </form>
        </div>

        <div id="booking-step-verify" style="display:none;">
            <h2>Vérification de votre email</h2>
            <p>Un code à 6 chiffres vient de vous être envoyé par email. Il est valable 15 minutes.</p>
            <form id="booking-verify-form">
                <label for="booking-code">Code de vérification</label>
                <input type="text" id="booking-code" inputmode="numeric" pattern="[0-9]*" maxlength="6" required>
                <button type="submit">Confirmer le rendez-vous</button>
            </form>
        </div>

        <div id="booking-step-error" style="display:none;">
            <p id="booking-error-message"></p>
        </div>
    </div>
</div>

<style>
    .booking-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }
    .booking-modal {
        position: relative;
        background: #fff;
        max-width: 480px;
        width: 90%;
        max-height: 85vh;
        overflow-y: auto;
        padding: 32px;
        border-radius: 8px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
    }
    .booking-modal-close {
        position: absolute;
        top: 12px;
        right: 16px;
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: #666;
    }
    .booking-modal form label {
        display: block;
        margin-top: 12px;
        font-weight: bold;
    }
    .booking-modal form input,
    .booking-modal form textarea {
        width: 100%;
        padding: 8px;
        margin-top: 4px;
        box-sizing: border-box;
    }
    .booking-modal form button {
        margin-top: 16px;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/locales-all.global.min.js"></script>
<script src="{{ asset('booking_global.js') }}"></script>
{% endblock %}

{% block importmap %}{% endblock %}