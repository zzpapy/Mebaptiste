<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Maître Baptiste Lebrou{% endblock %} - Avocat à Strasbourg</title>

    <meta name="description" content="{% block meta_description %}Maître Baptiste Lebrou, avocat au barreau de Strasbourg. Conseil et défense en droit pénal. Prise de rendez-vous en ligne.{% endblock %}">
    <link rel="canonical" href="{% block canonical_url %}{{ url(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')) }}{% endblock %}">

    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:title" content="{% block og_title %}{{ block('title') }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ block('meta_description') }}{% endblock %}">
    <meta property="og:url" content="{{ block('canonical_url') }}">
    <meta property="og:image" content="{% block og_image %}{{ absolute_url(asset('favicon.svg')) }}{% endblock %}">
    <meta property="og:locale" content="fr_FR">
    <meta property="og:site_name" content="Baptiste Lebrou - Avocat au barreau de Strasbourg">

    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{ block('og_title') }}">
    <meta name="twitter:description" content="{{ block('og_description') }}">
    <meta name="twitter:image" content="{{ block('og_image') }}">

    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    {% block schema_org %}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Attorney",
        "name": "Maître Baptiste Lebrou",
        "description": "Avocat au barreau de Strasbourg, conseil et défense en droit pénal.",
        "url": "{{ url('home') }}",
        "address": {
            "@type": "PostalAddress",
            "addressLocality": "Strasbourg",
            "addressCountry": "FR"
        },
        "areaServed": "Strasbourg"
    }
    </script>
    {% endblock %}
</head>
<body>
    <header class="site-header">
        <div class="header-inner">
            <a href="{{ path('home') }}" class="site-title">
                Baptiste Lebrou
                <small>AVOCAT AU BARREAU DE STRASBOURG</small>
            </a>
            <nav class="main-nav">
                <ul>
                    <li><a href="{{ path('home') }}">Accueil</a></li>
                    <li><a href="{{ path('page_show', {slug: 'a-propos'}) }}">À propos</a></li>
                    <li><a href="{{ path('page_show', {slug: 'domaines-dexpertise'}) }}">Domaines d'expertise</a></li>
                    <li><a href="{{ path('article_list') }}">Actualités</a></li>
                    {% for menuPage in menu_pages() %}
                        <li><a href="{{ path('page_show', {slug: menuPage.slug}) }}">{{ menuPage.title }}</a></li>
                    {% endfor %}
                    <li><a href="{{ path('booking_index') }}">Prendre rendez-vous</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        {% block body %}{% endblock %}
    </main>

    <footer class="site-footer">
        <p>&copy; {{ "now"|date("Y") }} Maître Baptiste Lebrou - Avocat au barreau de Strasbourg</p>
        <nav class="footer-nav">
            <a href="{{ path('page_show', {slug: 'mentions-legales'}) }}">Mentions légales</a>
            <span class="footer-separator">·</span>
            <a href="{{ path('page_show', {slug: 'politique-de-confidentialite'}) }}">Politique de confidentialité</a>
        </nav>
    </footer>

    {% block importmap %}{{ importmap('app') }}{% endblock %}
</body>
</html>
